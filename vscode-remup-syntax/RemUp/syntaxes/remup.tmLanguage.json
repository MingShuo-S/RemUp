{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "RemUp",
	"scopeName": "source.remup",
	"patterns": [
		{
			"include": "#archive"
		},
		{
			"include": "#card"
		},
		{
			"include": "#region"
		},
		{
			"include": "#sub-card"
		},
		{
			"include": "#code-block"
		},
		{
			"include": "#vibe-card"
		},
		{
			"include": "#inline-explanation"
		},
		{
			"include": "#list"
		},
		{
			"include": "#bold-text"
		},
		{
			"include": "#label"
		},
		{
			"include": "#comments"
		}
	],
	"repository": {
		"archive": {
			"name": "markup.heading.archive.remup",
			"patterns": [
				{
					"comment": "Markdown style archive - # 归档名",
					"name": "markup.heading.1.remup",
					"match": "^\\s*(#)\\s+([^#].*?)\\s*$",
					"captures": {
						"1": {
							"name": "punctuation.definition.heading.remup"
						},
						"2": {
							"name": "entity.name.section.archive.remup"
						}
					}
				},
				{
					"comment": "Traditional archive - --<名称>--",
					"name": "keyword.control.archive.remup",
					"match": "^\\s*--<([^>]+)>--\\s*$",
					"captures": {
						"1": {
							"name": "entity.name.function.archive-title.traditional.remup"
						}
					}
				}
			]
		},
		
		"card": {
			"name": "meta.card.remup",
			"patterns": [
				{
					"comment": "Markdown style card - ## 卡片主题",
					"name": "markup.heading.2.remup",
					"begin": "^\\s*(##)\\s+(.+?)\\s*$",
					"end": "(?=^\\s*(?:##|###|#)\\s+)|(?=^\\s*/\\+>\\s*$)|$",
					"beginCaptures": {
						"1": {
							"name": "punctuation.definition.heading.remup"
						},
						"2": {
							"name": "entity.name.title.card.remup"
						}
					},
					"patterns": [
						{
							"include": "#label"
						},
						{
							"include": "#region"
						},
						{
							"include": "#sub-card"
						},
						{
							"include": "#vibe-card"
						},
						{
							"include": "#inline-explanation"
						},
						{
							"include": "#code-block"
						},
						{
							"include": "#list"
						},
						{
							"include": "#bold-text"
						},
						{
							"match": ".+",
							"name": "string.quoted.other.remup"
						}
					]
				},
				{
					"comment": "Traditional card - <+主题 ... /+>",
					"name": "meta.card.traditional.remup",
					"begin": "^\\s*<\\+([^/]+)\\s*$",
					"end": "^\\s*/\\+>\\s*$",
					"beginCaptures": {
						"1": {
							"name": "entity.name.title.card.traditional.remup"
						}
					},
					"endCaptures": {
						"1": {
							"name": "keyword.control.card.end.remup"
						}
					},
					"patterns": [
						{
							"include": "#label"
						},
						{
							"include": "#region"
						},
						{
							"include": "#vibe-card"
						},
						{
							"include": "#inline-explanation"
						},
						{
							"include": "#code-block"
						},
						{
							"include": "#list"
						},
						{
							"include": "#bold-text"
						},
						{
							"match": ".+",
							"name": "string.quoted.other.remup"
						}
					]
				}
			]
		},
		
		"region": {
			"name": "meta.region.remup",
			"patterns": [
				{
					"comment": "Markdown style region - ### 区域名",
					"name": "markup.heading.3.remup",
					"match": "^\\s*(###)\\s+(.+?)\\s*$",
					"captures": {
						"1": {
							"name": "punctuation.definition.heading.remup"
						},
						"2": {
							"name": "entity.name.section.region-title.md.remup"
						}
					}
				},
				{
					"comment": "Traditional region - ---区域名",
					"name": "keyword.control.region.remup",
					"match": "^\\s*---\\s*([^\\s].*?)\\s*$",
					"captures": {
						"1": {
							"name": "entity.name.section.region-title.traditional.remup"
						}
					}
				}
			]
		},
		
		"sub-card": {
			"name": "markup.heading.4.remup",
			"comment": "Markdown style sub-card - #### 次级卡片",
			"match": "^\\s*(####)\\s+(.+?)\\s*$",
			"captures": {
				"1": {
					"name": "punctuation.definition.heading.remup"
				},
				"2": {
					"name": "entity.name.title.sub-card.md.remup"
				}
			}
		},
		
		"label": {
			"name": "meta.label.remup",
			"comment": "Label syntax - (符号：内容) supporting both Chinese and English colon",
			"match": "(\\()([^):：]+)([):：])\\s*([^)]+)",
			"captures": {
				"1": {
					"name": "punctuation.definition.label.begin.remup"
				},
				"2": {
					"name": "entity.name.type.tag-symbol.remup"
				},
				"3": {
					"name": "punctuation.definition.label.separator.remup"
				},
				"4": {
					"name": "string.quoted.label-content.remup"
				}
			}
		},
		
		"code-block": {
			"name": "markup.code.block.remup",
			"begin": "^\\s*(```)\\s*(\\w*)\\s*$",
			"end": "^\\s*(```)\\s*$",
			"beginCaptures": {
				"1": {
					"name": "punctuation.definition.code.begin.remup"
				},
				"2": {
					"name": "entity.name.type.language.remup"
				}
			},
			"endCaptures": {
				"1": {
					"name": "punctuation.definition.code.end.remup"
				}
			},
			"contentName": "meta.embedded.source",
			"patterns": [
				{
					"match": ".+",
					"name": "variable.parameter.code-content.remup"
				}
			]
		},
		
		"list": {
			"patterns": [
				{
					"name": "markup.list.ordered.remup",
					"match": "^\\s*(\\d+\\.)\\s+(.*)$",
					"captures": {
						"1": {
							"name": "punctuation.definition.list-item.ordered.remup"
						},
						"2": {
							"patterns": [
								{
									"include": "#inline-content"
								}
							]
						}
					}
				},
				{
					"name": "markup.list.unordered.remup",
					"match": "^\\s*(-)\\s+(.*)$",
					"captures": {
						"1": {
							"name": "punctuation.definition.list-item.unordered.remup"
						},
						"2": {
							"patterns": [
								{
									"include": "#inline-content"
								}
							]
						}
					}
				}
			]
		},
		
		"vibe-card": {
			"name": "meta.vibe-card.inline.remup",
			"patterns": [
				{
					"comment": "Markdown vibe card - [内容 | 批注]",
					"name": "meta.vibe-card.md.remup",
					"match": "(\\[)([^\\[\\]\\|]+)(\\s*)(\\|)(\\s*)([^\\[\\]]*)(\\])",
					"captures": {
						"1": {
							"name": "punctuation.definition.vibe.begin.md.remup"
						},
						"2": {
							"name": "entity.name.vibe-content.md.remup"
						},
						"3": {
							"name": "meta.whitespace.vibe.md.remup"
						},
						"4": {
							"name": "punctuation.definition.vibe.separator.md.remup"
						},
						"5": {
							"name": "meta.whitespace.vibe.md.remup"
						},
						"6": {
							"name": "string.quoted.annotation.md.remup"
						},
						"7": {
							"name": "punctuation.definition.vibe.end.md.remup"
						}
					}
				},
				{
					"comment": "Traditional vibe card - `内容 `[批注]",
					"name": "meta.vibe-card.traditional.remup",
					"match": "(`)([^`\\n]+)(`)(\\[)([^\\]\\n]*)(\\])",
					"captures": {
						"1": {
							"name": "punctuation.definition.vibe.begin.remup"
						},
						"2": {
							"name": "entity.name.vibe-content.traditional.remup"
						},
						"3": {
							"name": "punctuation.definition.vibe.end.remup"
						},
						"4": {
							"name": "punctuation.definition.annotation.begin.remup"
						},
						"5": {
							"name": "string.quoted.annotation.traditional.remup"
						},
						"6": {
							"name": "punctuation.definition.annotation.end.remup"
						}
					}
				}
			]
		},
		
		"inline-explanation": {
			"name": "meta.inline-explanation.remup",
			"patterns": [
				{
					"comment": "Markdown inline explanation - ^解释",
					"name": "meta.inline-explanation.md.remup",
					"match": "(\\^)([^\\n]+)",
					"captures": {
						"1": {
							"name": "punctuation.definition.explanation.remup"
						},
						"2": {
							"name": "string.unquoted.explanation.md.remup"
						}
					}
				},
				{
					"comment": "Traditional inline explanation - >>解释",
					"name": "meta.inline-explanation.traditional.remup",
					"match": "(>>)([^\\n]+)",
					"captures": {
						"1": {
							"name": "punctuation.definition.explanation.remup"
						},
						"2": {
							"name": "string.unquoted.explanation.traditional.remup"
						}
					}
				}
			]
		},
		
		"bold-text": {
			"name": "markup.bold.remup",
			"match": "\\*\\*([^*]+)\\*\\*"
		},
		
		"inline-content": {
			"patterns": [
				{
					"include": "#vibe-card"
				},
				{
					"include": "#inline-explanation"
				},
				{
					"include": "#bold-text"
				}
			]
		},
		
		"comments": {
			"patterns": [
				{
					"name": "comment.line.number-sign.remup",
					"match": "#.*$"
				}
			]
		}
	},
	"scopeName": "source.remup"
}