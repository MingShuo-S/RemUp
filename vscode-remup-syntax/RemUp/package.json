{
  "name": "RemUp",
  "displayName": "RemUp - 标记语言支持",
  "description": "RemUp 标记语言完整支持 - 语法高亮 + 自动换行 + 智能编辑 | 构建'学习 - 理解 - 再学习'的记忆闭环",
  "version": "1.1.0",
  "publisher": "MingShuo-S",
  "main": "./extension.js",
  "engines": {
    "vscode": "^1.108.1"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "RemUp",
    "markup language",
    "note-taking",
    "learning",
    "knowledge management",
    "markdown"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MingShuo-S/PPL_Project-RemUp.git"
  },
  "icon": "images/icon.png",
  "activationEvents": [
    "onLanguage:remup"
  ],
  "contributes": {
    "languages": [{
      "id": "remup",
      "aliases": ["RemUp", "remup"],
      "extensions": [".remup", ".ru"],
      "configuration": "./language-configuration.json",
      "icon": {
        "light": "images/icon-light.svg",
        "dark": "images/icon-dark.svg"
      }
    }],
    "grammars": [{
      "language": "remup",
      "scopeName": "source.remup",
      "path": "./syntaxes/remup.tmLanguage.json"
    }],
    "snippets": [
      {
        "language": "remup",
        "path": "./snippets/remup-snippets.json"
      }
    ],
    "configuration": {
      "title": "RemUp",
      "properties": {
        "remup.enableAutoWrap": {
          "type": "boolean",
          "default": true,
          "description": "为 RemUp 文件启用自动换行（类似 Markdown）",
          "scope": "resource"
        },
        "remup.wordWrapColumn": {
          "type": "number",
          "default": 120,
          "description": "RemUp 文件自动换行列宽",
          "scope": "resource"
        }
      }
    }
  }
}