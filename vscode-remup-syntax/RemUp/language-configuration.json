{
    "comments": {
        // RemUp uses # for comments (Markdown-style)
        "lineComment": "#"
    },
    // symbols used as brackets
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["<+", "/+>"]
    ],
    // symbols that are auto closed when typing
    "autoClosingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""],
        ["'", "'"],
        {"open": "<+", "close": "/+>", "notIn": ["string"]},
        {"open": "```", "close": "```", "notIn": ["string"]}
    ],
    // symbols that can be used to surround a selection
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""],
        ["'", "'"],
        ["*", "*"],
        ["`", "`"]
    ],
    // folding markers configuration
    "folding": {
        "markers": {
            "start": "^\\s*(#|##|###|####|--<|<\\+)\\s*",
            "end": "^\\s*/\\+>\\s*$"
        }
    },
    // word pattern for RemUp
    "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\]\\{\\}\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)"
}